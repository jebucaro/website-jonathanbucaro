    "headers" : [
      {
        "source": "**",
        "headers" : [
          { "key" : "Content-Security-Policy", "value" : "default-src 'self' https:; style-src 'unsafe-inline' 'self' https://unpkg.com https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; form-action 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests; block-all-mixed-content" }, 
          { "key" : "X-Frame-Options", "value" : "SAMEORIGIN" }, 
          { "key" : "X-Content-Type-Options", "value" : "nosniff" }, 
          { "key" : "Referrer-Policy", "value" : "strict-origin-when-cross-origin" }, 
          { "key" : "Permissions-Policy", "value" : "geolocation=()" }, 
          { "key" : "Cache-Control", "value" : "public, max-age=3600" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=180, public"
          }
        ]
      },
      {
        "source": "/**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600, public"
          }
        ]
      },
      {
        "source": "/js/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=604800, public"
          }
        ]
      }
    ]
  }
