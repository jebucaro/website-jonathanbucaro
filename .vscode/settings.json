{
    "files.encoding": "utf8",
    "prettier.prettierPath": "./node_modules/prettier",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "[markdown]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "prettier.tabWidth": 4,
    "editor.useTabStops": true
}
