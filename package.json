{
    "name": "hugo-personal",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "dev": "hugo server -D --disableFastRender --printMemoryUsage --printPathWarnings --printUnusedTemplates --templateMetrics --templateMetricsHints",
        "build": "hugo --cleanDestinationDir --minify",
        "build:staging": "hugo --cleanDestinationDir --minify --environment staging",
        "clean": "node -e \"const fs = require('fs'); ['public', 'resources'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:markdown": "markdownlint 'content/**/*.md'",
        "lint:markdown:fix": "markdownlint --fix 'content/**/*.md'",
        "check": "pnpm run format:check && pnpm run lint:markdown",
        "fix": "pnpm run format:write && pnpm run lint:markdown:fix",
        "validate": "pnpm run check && pnpm run build",
        "prepare": "husky"
    },
    "author": "",
    "license": "UNLICENSED",
    "description": "",
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@10.32.1",
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "markdownlint-cli": "^0.49.0",
        "prettier": "^3.8.4",
        "prettier-plugin-go-template": "^0.0.15"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,scss,sass,less}": [
            "prettier --write"
        ],
        "content/**/*.md": [
            "prettier --write",
            "markdownlint --fix"
        ]
    },
    "pnpm": {
        "overrides": {
            "brace-expansion": "5.0.6",
            "minimatch": ">=10.1.4"
        }
    },
    "dependencies": {
        "chart.js": "^4.5.1",
        "lightense-images": "^1.0.17",
        "normalize.css": "^8.0.1",
        "reframe.js": "^4.0.2",
        "tiny-slider": "^2.9.4"
    }
}
