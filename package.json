{
    "name": "hugo-personal",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:markdown": "markdownlint **/*.md --ignore node_modules --ignore public --ignore resources",
        "build": "hugo --cleanDestinationDir --minify",
        "dev": "hugo server -D --disableFastRender --printI18nWarnings --printMemoryUsage --printPathWarnings --printUnusedTemplates --templateMetrics --templateMetricsHints",
        "prepare": "husky"
    },
    "author": "",
    "license": "UNLICENSED",
    "description": "",
    "devDependencies": {
        "husky": "^9.1.6",
        "lint-staged": "^15.2.10",
        "markdownlint-cli": "^0.44.0",
        "prettier": "^3.3.3",
        "prettier-plugin-go-template": "^0.0.15"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,scss,sass,less}": [
            "prettier --write"
        ],
        "*.md": [
            "prettier --write",
            "markdownlint **/*.md --ignore node_modules --ignore public --ignore resources"
        ],
        "*.html": [
            "prettier --write --parser go-template"
        ]
    }
}
