{
    "name": "hugo-personal",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "dev": "hugo server -D --disableFastRender --printMemoryUsage --printPathWarnings --printUnusedTemplates --templateMetrics --templateMetricsHints",
        "build": "hugo --cleanDestinationDir --minify",
        "build:staging": "hugo --cleanDestinationDir --minify --environment staging",
        "clean": "node -e \"const fs = require('fs'); ['public', 'resources'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:markdown": "markdownlint 'content/**/*.md'",
        "lint:markdown:fix": "markdownlint --fix 'content/**/*.md'",
        "check": "npm run format:check && npm run lint:markdown",
        "fix": "npm run format:write && npm run lint:markdown:fix",
        "validate": "npm run check && npm run build",
        "prepare": "husky"
    },
    "author": "",
    "license": "UNLICENSED",
    "description": "",
    "devDependencies": {
        "husky": "^9.1.6",
        "lint-staged": "^16.2.7",
        "markdownlint-cli": "^0.47.0",
        "prettier": "^3.8.1",
        "prettier-plugin-go-template": "^0.0.15"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,scss,sass,less}": [
            "prettier --write"
        ],
        "content/**/*.md": [
            "prettier --write",
            "markdownlint --fix"
        ]
    },
    "dependencies": {
        "chart.js": "^4.5.0",
        "lightense-images": "^1.0.17",
        "mermaid": "^10.9.5",
        "reframe.js": "^4.0.2",
        "smoothscroll-polyfill": "^0.4.4",
        "tiny-slider": "^2.9.4",
        "vanilla-lazyload": "^19.1.3"
    }
}
