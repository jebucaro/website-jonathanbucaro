{
  "name": "hugo-personal",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "build": "hugo --cleanDestinationDir --minify",
    "prepare": "husky"
  },
  "author": "",
  "license": "UNLICENSED",
  "description": "",
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-go-template": "^0.0.15"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,sass,less,md}": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write --parser go-template"
    ]
  }
}
